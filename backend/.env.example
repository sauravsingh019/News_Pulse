# Copy to .env and adjust for your environment.

PORT=4000

# Path to the shared SQLite DB written by the Python scraper.
# Must match NEWS_PULSE_DB used by the scraper (defaults to ../data/news_pulse.db).
NEWS_PULSE_DB=../data/news_pulse.db

# Absolute or relative path to a python3 interpreter that has the scraper's
# requirements.txt installed (use the venv's python if you made one).
PYTHON_BIN=python3

# Path to the scraper folder (run.py lives here).
SCRAPER_DIR=../scraper

# Comma-separated origins allowed to call this API (your deployed frontend URL).
CORS_ORIGIN=http://localhost:3000
